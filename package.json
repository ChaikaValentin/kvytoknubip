{
  "name": "kvytok",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Kvytok — сервіс купівлі квитків у кіно",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"node server/index.js\" \"npm --prefix client run dev\"",
    "seed": "node server/seed.js",
    "build": "npm --prefix client run build",
    "start": "NODE_ENV=production node server/index.js",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
